CLASS lsc_zcds_fiaf27_errores DEFINITION INHERITING FROM cl_abap_behavior_saver.

  "=========
  PUBLIC SECTION.

    CLASS-DATA: gt_pr_data TYPE zcl_fiaf27_solpedaf=>ty_t_purchase_req.

  PROTECTED SECTION.

    METHODS save_modified REDEFINITION.


ENDCLASS.

CLASS lsc_zcds_fiaf27_errores IMPLEMENTATION.

  METHOD save_modified.

  DATA: lt_return TYPE ztt_bapiret2,

        lt_result TYPE zttasset_create_out.

*--------------------------------------

* Cost center split structure

*--------------------------------------

  TYPES: BEGIN OF ty_cc_split,

           costcenter TYPE kostl,

           qty        TYPE ebkn-menge,

         END OF ty_cc_split.

  TYPES: ty_t_cc_split TYPE STANDARD TABLE OF ty_cc_split WITH EMPTY KEY.

*--------------------------------------

* Group structure

*--------------------------------------

  TYPES: BEGIN OF ty_group,

           pr          TYPE i_purchaserequisitionitem-purchaserequisition,

           pr_item     TYPE i_purchaserequisitionitem-purchaserequisitionitem,

           total_qty   TYPE ebkn-menge,

           description TYPE ztactivos_fijos-comentario,

           isocode     TYPE a_purchaserequisitionitem_2-baseunitisocode,

           assign      TYPE ebkn-zebkn,

           cc_split    TYPE ty_t_cc_split,

         END OF ty_group.

  DATA: lt_group TYPE STANDARD TABLE OF ty_group,

        ls_group TYPE ty_group.

*--------------------------------------

* Build grouping + split

*--------------------------------------

  LOOP AT gt_pr_data INTO DATA(ls_data).

    READ TABLE lt_group ASSIGNING FIELD-SYMBOL(<ls_group>)

      WITH KEY

        pr      = ls_data-purchaserequisition

        pr_item = ls_data-purchaserequisitionitem.

    IF sy-subrc = 0.

      <ls_group>-total_qty = <ls_group>-total_qty + ls_data-quantity.

      APPEND VALUE #(

        costcenter = ls_data-costcenter

        qty        = ls_data-quantity

      ) TO <ls_group>-cc_split.



    ELSE.

      CLEAR ls_group.

      ls_group-pr          = ls_data-purchaserequisition.

      ls_group-pr_item     = ls_data-purchaserequisitionitem.

      ls_group-total_qty   = ls_data-quantity.

      ls_group-description = ls_data-comentario.

      ls_group-isocode     = ls_data-baseunitisocode.

      ls_group-assign      = ls_data-purchasereqnacctassgmtnumber.

      APPEND VALUE #(

        costcenter = ls_data-costcenter

        qty        = ls_data-quantity

      ) TO ls_group-cc_split.

      APPEND ls_group TO lt_group.

    ENDIF.

  ENDLOOP.

*--------------------------------------

* Call FM once per PR item

*--------------------------------------

  DATA: lt_return_all TYPE ztt_bapiret2,

        lt_result_all TYPE zttasset_create_out.

  LOOP AT lt_group INTO ls_group.

    DATA: lt_return_fm TYPE ztt_bapiret2,

          lt_result_fm TYPE zttasset_create_out.

    CALL FUNCTION 'ZFM_ASSET_CR_AND_PR_UPD' DESTINATION 'NONE'

      EXPORTING

        iv_pr          = ls_group-pr

        iv_pr_item     = ls_group-pr_item

        iv_quantity    = ls_group-total_qty

        iv_description = ls_group-description

        iv_isocode     = ls_group-isocode

        iv_assign      = ls_group-assign



      IMPORTING

        et_return      = lt_return_fm

        et_result      = lt_result_fm
          TABLES

        it_cc_split    = ls_group-cc_split.   " <-- new
    APPEND LINES OF lt_return_fm TO lt_return_all.

    APPEND LINES OF lt_result_fm TO lt_result_all.

  ENDLOOP.

  lt_return = lt_return_all.

  lt_result = lt_result_all.

  CLEAR gt_pr_data.

LOOP AT lt_return_all INTO DATA(ls_return).
DATA(lv_severity) = COND #(
WHEN ls_return-type = 'E' OR ls_return-type = 'A' THEN if_abap_behv_message=>severity-error
WHEN ls_return-type = 'W' THEN if_abap_behv_message=>severity-warning
ELSE if_abap_behv_message=>severity-success
).
DATA(lo_msg) = new_message( id = ls_return-id number = ls_return-number severity = lv_severity
v1 =  ls_return-message_v1
v2 = ls_return-message_v2
v3 = ls_return-message_v3
v4 = ls_return-message_v4 ).

APPEND lo_msg TO reported-%other.

ENDLOOP.
    "data(lo_dest) = cl_bgmc_process_factory



  ENDMETHOD.

ENDCLASS.

CLASS lhc_errores DEFINITION INHERITING FROM cl_abap_behavior_handler.
  PRIVATE SECTION.

    METHODS get_instance_authorizations FOR INSTANCE AUTHORIZATION
      IMPORTING keys REQUEST requested_authorizations FOR errores RESULT result.

    METHODS createasset FOR MODIFY
      IMPORTING keys FOR ACTION errores~createasset RESULT result.

    "METHODS logerror FOR MODIFY
    " IMPORTING keys FOR ACTION errores~logerror.

ENDCLASS.

CLASS lhc_errores IMPLEMENTATION.

  METHOD get_instance_authorizations.
  ENDMETHOD.

  METHOD createasset.
    " 1. Instanciar tu clase motor global
    DATA(lo_gestor) = NEW zcl_fiaf27_solpedaf( ).
    TYPES: BEGIN OF ty_asset_cc,
             asset TYPE anln1,
             cc    TYPE  ebkn-kostl,
           END OF ty_asset_cc,
           ty_t_asset_cc TYPE STANDARD TABLE OF ty_asset_cc WITH EMPTY KEY.
    " Variables auxiliares para la selección fresca
    DATA: lt_rng_banfn    TYPE zcl_fiaf27_solpedaf=>tr_banfn,
          lt_rng_bnfpo    TYPE zcl_fiaf27_solpedaf=>tr_bnfpo,
          lt_fresh_data   TYPE zcl_fiaf27_solpedaf=>ty_t_purchase_req,
          lv_net_value    TYPE p LENGTH 15 DECIMALS 9,
          lv_quantity_int TYPE i,
          lv_msg          TYPE string,
          lv_asset        TYPE anln1,
          lt_asset_cc     TYPE  ty_t_asset_cc,
          lv_assignments  TYPE ebkn-zebkn.


    LOOP AT keys INTO DATA(ls_key). "sirve para ir fila a fila de las que se ha saeleccionado.

      " -----------------------------------------------------------------------
      " PASO A: Preparar filtro para buscar el dato REAL en SAP
      " -----------------------------------------------------------------------
      CLEAR: lt_rng_banfn,lt_rng_bnfpo.
*     APPEND VALUE #( sign = 'I' option = 'EQ' low = ls_key-%param-PurchaseRequisition ) TO lt_rng_banfn. "commented by srividwan
      APPEND VALUE #( sign = 'I' option = 'EQ' low = ls_key-purchaserequisition ) TO lt_rng_banfn. "inserted by srividwan
      APPEND VALUE #( sign = 'I' option = 'EQ' low = ls_key-purchaserequisitionitem ) TO lt_rng_bnfpo.
      " -----------------------------------------------------------------------
      " PASO B: Leer datos frescos de la CDS Estándar (EBAN)
      " -----------------------------------------------------------------------
      " Llamamos al método de selección de tu clase global
      lt_fresh_data = lo_gestor->select_data_from_main_cds(
          iv_banfn = lt_rng_banfn
          iv_bnfpo = lt_rng_bnfpo
          iv_knttp = ''
          " No pasamos más filtros para asegurarnos de traer la solped aunque haya cambiado de centro
      ).
      "  SORT lt_fresh_data BY purchasereqnacctassgmtnumber DESCENDING.
      DATA(lv_last) = lines( lt_fresh_data ).
      " data(ls_fresh_req) = lt_fresh_data[ 1 ].
      lv_assignments = lt_fresh_data[ lv_last ]-purchasereqnacctassgmtnumber.

      IF lt_fresh_data IS NOT INITIAL.
        LOOP AT lt_fresh_data INTO DATA(ls_fresh_req).
          " -----------------------------------------------------------------------
          " A PARTIR DE AQUÍ USAMOS ls_fresh_req (DATOS FRESCOS), NO ls_key
          " -----------------------------------------------------------------------

          " 3. Cargar datos maestros masivamente para esta línea (Usando datos frescos)
          lo_gestor->select_data_for_assets( VALUE #( ( ls_fresh_req ) ) ).

          " 4. Validar la posición (Usando datos frescos)
          DATA: lv_valid TYPE char1.

          lo_gestor->delete_from_final_table(
                    EXPORTING
                    iv_pr = ls_fresh_req-purchaserequisition
                    iv_item = ls_fresh_req-purchaserequisitionitem
                    ).

          lo_gestor->validate_assets(
            EXPORTING is_purchase_req = ls_fresh_req  " <--- CAMBIO AQUÍ
            RECEIVING rv_is_valid     = lv_valid
          ).

          IF lv_valid = 'X'.


            " B) PREPARAR TABLAS BAPI (Items)
*    ls_fresh_req-accountassigmentcategory ='A'.


            " C) DESGLOSE Y CREACIÓN ACTIVOS
            IF ls_fresh_req-quantity > 0.
              lv_net_value = ls_fresh_req-purreqnnetamount / ls_fresh_req-quantity.
              lv_quantity_int = ls_fresh_req-quantity.
            ELSE.
              lv_net_value = 0.
              lv_quantity_int = 1.
            ENDIF.
" appended to global internal table after validations are okay.
            APPEND ls_fresh_req TO lsc_zcds_fiaf27_errores=>gt_pr_data.
          ENDIF.
        ENDLOOP.

        " 6. Devolver el número de activo al JavaScript
         ENDIF.
    ENDLOOP.
  ENDMETHOD.
ENDCLASS.
