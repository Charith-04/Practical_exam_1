  IF sy-subrc <> 0 OR ls_eban-werks IS INITIAL OR ls_eban-matnr IS INITIAL.

    APPEND VALUE #( type = 'E' message = 'PR data not found' ) TO et_return.

    RETURN.

  ENDIF.
 
