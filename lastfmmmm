* PR Update

*==============================

  DATA(lv_res) TYPE string.
 
  lo_obj->update_purchase_requisition(

    EXPORTING

      iv_pr          = iv_pr

      iv_pr_item     = iv_pr_item

      iv_aa_cat      = 'A'

      iv_aa_number   = iv_assign

