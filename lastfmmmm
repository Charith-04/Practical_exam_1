    READ TABLE lt_purchase_req INTO ls_purchase_req INDEX 1.
 
    lo_obj->create_single_asset(

      EXPORTING

        is_purchase_req = ls_purchase_req

        iv_commit       = space

      IMPORTING

        ev_asset        = lv_asset

        ev_sub_num      = lv_sub

