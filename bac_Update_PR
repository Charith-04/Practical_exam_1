  METHOD create_single_asset.

    DATA: ls_gen           TYPE bapi1022_feglg001,
          ls_genx          TYPE bapi1022_feglg001x,
          ls_time          TYPE bapi1022_feglg003,
          ls_timex         TYPE bapi1022_feglg003x,
          ls_comp          TYPE bapi1022_1-comp_code,
          ls_return_bapi   TYPE bapiret2,
          ls_asset_created TYPE bapi1022_reference.

    " Variables locales
    DATA: ls_sociedad TYPE ty_sociedad,
          ls_bklas    TYPE ty_act_fijo,
          ls_clase_af TYPE ty_clase_activos,
          ls_material TYPE ty_materials.

    CLEAR: ev_asset, ev_sub_num, et_return.

    " --- MAPEO ---
    READ TABLE mt_sociedad INTO ls_sociedad WITH KEY bwkey = is_purchase_req-plant.
    ls_comp = ls_sociedad-bukrs.

    READ TABLE mt_bklas INTO ls_bklas WITH KEY material = is_purchase_req-material plant = is_purchase_req-plant.
    READ TABLE mt_clase_activos INTO ls_clase_af WITH KEY bklas = ls_bklas-valuationclass.
    ls_gen-assetclass = ls_clase_af-anlkl.
    ls_genx-assetclass = abap_true.

    READ TABLE mt_material INTO ls_material WITH KEY matnr = is_purchase_req-material.
    IF sy-subrc = 0.
      ls_gen-descript = ls_material-desc.
    ELSE.
      ls_gen-descript = is_purchase_req-material.
    ENDIF.
    ls_genx-descript = abap_true.

    ls_time-costcenter = is_purchase_req-costcenter.
    ls_timex-costcenter = abap_true.

    " --- LLAMADA BAPI ---
    CALL FUNCTION 'BAPI_FIXEDASSET_CREATE' DESTINATION 'NONE'
      EXPORTING
        companycode        = ls_comp
        generaldata        = ls_gen
        generaldatax       = ls_genx
        timedependentdata  = ls_time
        timedependentdatax = ls_timex
      IMPORTING
        assetcreated       = ls_asset_created
        return             = ls_return_bapi.

    " --- GESTION RETORNO ---
    IF ls_return_bapi-type = 'E' OR ls_return_bapi-type = 'A'.
      APPEND ls_return_bapi TO et_return.
*      CALL FUNCTION 'BAPI_TRANSACTION_ROLLBACK'.
    ELSE.
      ev_asset   = ls_asset_created-asset.
      ev_sub_num = ls_asset_created-subnumber.
      IF iv_commit = 'X'.
*      CALL FUNCTION 'BAPI_TRANSACTION_COMMIT' EXPORTING wait = abap_true.
      ENDIF.
    ENDIF.
  ENDMETHOD.


  METHOD update_solped_bapi.

    DATA: lt_return TYPE TABLE OF bapiret2.

    CLEAR: ev_success, ev_msg.

    " Llamada a la BAPI
    CALL FUNCTION 'BAPI_PR_CHANGE'
      EXPORTING
        number     = is_purchase_req-purchaserequisition
      TABLES
        return     = lt_return
        pritem     = it_pritem
        pritemx    = it_pritemx
        praccount  = it_praccount
        praccountx = it_praccountx.

    " Verificar errores
    DATA: lv_error TYPE abap_bool.

    LOOP AT lt_return INTO DATA(ls_ret) WHERE type = 'E' OR type = 'A'.
      lv_error = abap_true.
      ev_msg   = ls_ret-message. " Devolvemos el mensaje al reporte
      EXIT.
    ENDLOOP.

    IF lv_error = abap_true.
      CALL FUNCTION 'BAPI_TRANSACTION_ROLLBACK'.

      " Guardar Error en Tabla Z (llamada interna)
      me->add_to_final_table( is_purchase_req = is_purchase_req iv_msg = ev_msg ).

      ev_success = ' '. " Falso

    ELSE.
      CALL FUNCTION 'BAPI_TRANSACTION_COMMIT' EXPORTING wait = abap_true.

      " ÉXITO: Borrar de tabla Z si existía
      DATA: ls_zdb TYPE ztactivos_fijos.
      ls_zdb-banfn = is_purchase_req-purchaserequisition.
      ls_zdb-bnfpo = is_purchase_req-purchaserequisitionitem.

      DELETE FROM ztactivos_fijos
        WHERE banfn = ls_zdb-banfn
          AND bnfpo = ls_zdb-bnfpo.

      ev_success = 'X'. " Verdadero
      ev_msg = 'Solped actualizada correctamente'.
    ENDIF.



  ENDMETHOD.


  METHOD get_csrf_token.
    DATA : lo_req    TYPE REF TO if_http_request,
           lo_res    TYPE REF TO if_http_response,
           lt_fields TYPE tihttpnvp,
           ls_field  TYPE ihttpnvp.

    lo_req->set_method( lc_get ).
    lo_req->set_header_field( name = lc_token value = lc_fetch ).
    lo_req->set_header_field( name = lc_accept value = lc_appj ).
    lo_req->set_header_field( name = lc_uri value = iv_root ).

    io_client->send(  ).
    io_client->receive(  ).

    "Read token

    ev_csrf = io_client->response->get_header_field( lc_token ).

    "Read cookie
    io_client->response->get_header_fields( CHANGING fields = lt_fields ).
    LOOP AT lt_fields INTO ls_field WHERE name = 'Set-Cookie'.
      IF ev_cookie IS INITIAL.
        ev_cookie = ls_field-value.
      ELSE.
        ev_cookie = ev_cookie && ';' && ls_field-value.
      ENDIF.
    ENDLOOP.
* *   lo_res = io_http->execute( i_method = if_web_http_client=>get ).

*   IF lo_res->get_status(  )-code BETWEEN 200 AND 299.
