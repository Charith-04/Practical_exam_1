  METHOD select_data_from_main_cds.
    TYPES: tr_knttp TYPE RANGE OF knttp.
    DATA: lt_purchase_req TYPE TABLE OF ty_purchase_req,
          lt_knttp TYPE tr_knttp.

    CLEAR lt_purchase_req.

    APPEND VALUE #( sign = 'I' option = 'EQ' low = iv_knttp ) TO lt_knttp.

    SELECT a~purchaserequisition, a~purchaserequisitionitem, a~purchaserequisitiontype,
      a~supplier, a~material, a~purchasinggroup,
       a~plant, a~purreqnitemcurrency, a~accountassignmentcategory,
      c~costcenter, c~masterfixedasset, c~quantity, c~purreqnnetamount,
      c~wbselementinternalid, c~purchasereqnacctassgmtnumber, d~UnitOfMeasureISOCode as BaseUnitISOCode
      FROM i_purchaserequisitionitemapi01 AS a
      LEFT OUTER JOIN i_purreqnacctassgmtapi01 AS c ON
      a~purchaserequisition = c~purchaserequisition
      AND a~purchaserequisitionitem = c~purchaserequisitionitem
      LEFT OUTER JOIN I_UnitOfMeasure as d ON d~UnitOfMeasure = a~BaseUnit
      WHERE a~isdeleted = ' '
      AND a~accountassignmentcategory = 'Y' " replaced 'Y' with range variable which contain default value as 'Y'
      AND a~purchaserequisition IN @iv_banfn
      AND a~purchasinggroup IN @iv_ekgrp
      AND a~creationdate IN @iv_erdat
      AND c~costcenter IN @iv_kostl
      AND a~plant IN @iv_werks
      AND a~PurchaseRequisitionItem IN @iv_bnfpo " insert by srividwan
      INTO CORRESPONDING FIELDS OF TABLE @lt_purchase_req.

    CLEAR rt_purchase_req.

    rt_purchase_req = lt_purchase_req.


  ENDMETHOD.


