  METHOD reprocess_log_table.
    DATA: lt_purchase_req TYPE TABLE OF ty_purchase_req.
    TYPES:
      BEGIN OF ty_req,
        purchaserequisition          TYPE eban-banfn,
        purchaserequisitionitem      TYPE eban-bnfpo,
        purchaserequisitiontype      TYPE eban-bsart,
        supplier                     TYPE eban-lifnr,
        material                     TYPE eban-matnr,
        purchasinggroup              TYPE eban-ekgrp,
        plant                        TYPE eban-werks,
        purreqnitemcurrency          TYPE eban-waers,
        accountassignmentcategory     TYPE eban-knttp,
        costcenter                   TYPE ebkn-kostl,
        masterfixedasset             TYPE ebkn-anln1,
        quantity                     TYPE ebkn-menge,
        purreqnnetamount             TYPE eban-preis,
        wbselementinternalid         TYPE ebkn-ps_psp_pnr,
        purchasereqnacctassgmtnumber TYPE ebkn-zebkn,
        comentario                   TYPE ztactivos_fijos-comentario,
      END OF ty_req.
    SELECT * FROM ztactivos_fijos WHERE banfn IN @iv_pr AND
                                        bnfpo IN @iv_item
                                   INTO TABLE @DATA(lt_errlog).
    LOOP AT lt_errlog ASSIGNING FIELD-SYMBOL(<lfs_errlog>).

      DATA(ls_req) = VALUE ty_req(
        purchaserequisition          = <lfs_errlog>-banfn
        purchaserequisitionitem      = <lfs_errlog>-bnfpo
        purchaserequisitiontype      = <lfs_errlog>-bsart
        supplier                     = <lfs_errlog>-lifnr
        material                     = <lfs_errlog>-matnr
        purchasinggroup              = <lfs_errlog>-ekgrp
        plant                        = <lfs_errlog>-werks
        purreqnitemcurrency          = <lfs_errlog>-waers
        accountassignmentcategory    = <lfs_errlog>-knttp
        costcenter                   = <lfs_errlog>-kostl
        quantity                     = <lfs_errlog>-menge
        purreqnnetamount             = <lfs_errlog>-preis
        wbselementinternalid         = <lfs_errlog>-ps_psp_pnr
        purchasereqnacctassgmtnumber = <lfs_errlog>-zebkn
        masterfixedasset             = <lfs_errlog>-anln1
        comentario                   = <lfs_errlog>-comentario
      ).
      APPEND ls_req TO lt_purchase_req.
    ENDLOOP.
    rt_purchase_req = lt_purchase_req.
  ENDMETHOD.
